# Port for the Express server (bound to 127.0.0.1)
PORT=3000

# 64+ char random hex — generate with:  node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
SESSION_SECRET=

# bcrypt hash of your admin password — generate with:
#   node -e "console.log(require('bcrypt').hashSync('your-password-here', 12))"
ADMIN_PASSWORD_HASH=

# Root directory for media storage. The app creates `files/` and `db/` inside.
# Must be writable by the process user.
MEDIA_PATH=/srv/media

# Public URL where the CDN file_server serves /srv/media/files/ (no trailing slash)
CDN_BASE_URL=https://cdn.example.com

# Optional: the base URL where the admin WUI is served (used by log-scanner to
# distinguish external referers from self-referers). If unset, only CDN_BASE_URL
# counts as self.
# LUNA_BASE_URL=https://luna.example.com

# Optional: path to the CDN access log (Caddy JSON format). Defaults to
# /var/log/caddy/cdn-access.log. Used by the log scanner to mark files as
# "referenced" when consumed from external apps.
# CDN_ACCESS_LOG=/var/log/caddy/cdn-access.log
